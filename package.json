{
	"name": "comapeo-desktop",
	"productName": "CoMapeo Desktop",
	"private": true,
	"version": "0.3.0-pre",
	"description": "Desktop application for CoMapeo",
	"keywords": [],
	"author": {
		"name": "Awana Digital",
		"email": "info@awana.digital"
	},
	"contributors": [
		{
			"name": "Andrew Chou",
			"email": "andrewchou@fastmail.com"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/digidem/comapeo-desktop.git"
	},
	"license": "GPL-3.0",
	"type": "module",
	"main": "src/main/index.ts",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "~24.17.0",
			"onFail": "warn"
		},
		"packageManager": {
			"name": "npm",
			"version": "^11.17.0",
			"onFail": "warn"
		}
	},
	"scripts": {
		"postinstall": "patch-package",
		"prepare": "husky",
		"start": "run-s --print-name --node-run intl forge:start",
		"forge:start": "electron-forge start",
		"forge:package": "electron-forge package",
		"forge:make": "electron-forge make",
		"intl:extract": "node scripts/extract-messages.ts",
		"intl:compile": "node scripts/compile-messages.ts",
		"intl:generate": "node scripts/generate-translated-languages-list.ts",
		"intl": "run-s --print-name --print-label --node-run intl:extract intl:compile intl:generate",
		"checks:eslint": "eslint --cache .",
		"checks:format": "prettier --cache --check .",
		"checks:knip": "knip --cache",
		"checks": "run-p --print-name --print-label --aggregate-output --node-run --continue-on-error checks:*",
		"types:root": "tsc -p tsconfig.json",
		"types:shared": "tsc -p src/shared/tsconfig.json",
		"types:main": "tsc -p src/main/tsconfig.json",
		"types:tests-e2e": "tsc -p tests-e2e/tsconfig.json",
		"types:services": "tsc -p src/services/tsconfig.json",
		"types:preload": "tsc -p src/preload/tsconfig.json",
		"types:renderer": "tsc -p src/renderer/tsconfig.json",
		"types": "run-p --print-name --print-label --aggregate-output --node-run --continue-on-error types:*",
		"test:main": "vitest run --dir ./src/main/",
		"test:renderer": "vitest run --config ./src/renderer/vite.config.js",
		"test:shared": "vitest run --dir ./src/shared/",
		"test": "run-p --print-name --print-label --aggregate-output --node-run --continue-on-error test:*",
		"test-e2e": "playwright test",
		"vite:dev": "vite dev src/renderer",
		"vite:build": "vite build src/renderer"
	},
	"dependencies": {
		"@comapeo/core": "7.3.0",
		"@comapeo/default-categories": "1.1.0",
		"@comapeo/fallback-smp": "1.0.0",
		"@comapeo/ipc": "8.0.0",
		"@comapeo/map-server": "1.1.4",
		"@formatjs/intl": "4.1.13",
		"@homebridge/ciao": "1.3.9",
		"@mapeo/crypto": "1.1.0",
		"@sentry/electron": "7.13.0",
		"atomically": "2.1.1",
		"electron-context-menu": "4.1.2",
		"electron-dl": "4.0.0",
		"electron-squirrel-startup": "1.0.1",
		"fastify": "4.29.1",
		"obug": "2.1.3",
		"sodium-native": "4.3.3",
		"systeminformation": "5.31.10",
		"tiny-typed-emitter": "2.1.0",
		"valibot": "1.4.1",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@comapeo/core-react": "11.0.7",
		"@electron-forge/cli": "7.11.2",
		"@electron-forge/maker-deb": "7.11.2",
		"@electron-forge/maker-dmg": "7.11.2",
		"@electron-forge/maker-rpm": "7.11.2",
		"@electron-forge/maker-squirrel": "7.11.2",
		"@electron-forge/maker-zip": "7.11.2",
		"@electron-forge/plugin-auto-unpack-natives": "7.11.2",
		"@electron-forge/plugin-base": "7.11.2",
		"@electron-forge/plugin-fuses": "7.11.2",
		"@electron-forge/shared-types": "7.11.2",
		"@electron/fuses": "1.8.0",
		"@emotion/react": "11.14.0",
		"@emotion/styled": "11.14.1",
		"@eslint-react/eslint-plugin": "5.9.2",
		"@eslint/js": "10.0.1",
		"@fontsource-variable/rubik": "5.2.8",
		"@formatjs/cli-lib": "8.7.10",
		"@formatjs/unplugin": "1.1.19",
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@mui/material": "9.1.2",
		"@playwright/test": "1.61.1",
		"@reforged/maker-appimage": "5.2.0",
		"@rolldown/plugin-babel": "0.2.3",
		"@sentry/react": "10.50.0",
		"@sentry/vite-plugin": "5.3.0",
		"@tanstack/eslint-plugin-query": "5.101.1",
		"@tanstack/eslint-plugin-router": "1.162.0",
		"@tanstack/react-form": "1.33.0",
		"@tanstack/react-query": "5.101.1",
		"@tanstack/react-router": "1.170.16",
		"@tanstack/react-virtual": "3.14.3",
		"@tanstack/router-plugin": "1.168.18",
		"@turf/bbox": "7.3.5",
		"@turf/bbox-polygon": "7.3.5",
		"@turf/center": "7.3.5",
		"@turf/helpers": "7.3.5",
		"@turf/random": "7.3.5",
		"@types/geojson": "7946.0.16",
		"@types/node": "24.13.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/semver": "7.7.1",
		"@types/sodium-native": "2.3.9",
		"@types/utm": "1.1.4",
		"@vitejs/plugin-react": "6.0.3",
		"babel-plugin-react-compiler": "1.0.0",
		"date-fns": "4.4.0",
		"electron": "42.5.0",
		"electron-playwright-helpers": "2.1.0",
		"eslint": "10.5.0",
		"eslint-plugin-formatjs": "6.4.15",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.3",
		"globals": "17.7.0",
		"husky": "9.1.7",
		"knip": "6.20.0",
		"maplibre-gl": "5.24.0",
		"nano-staged": "1.0.2",
		"network-information-types": "0.1.1",
		"npm-run-all2": "9.0.2",
		"patch-package": "8.0.1",
		"playwright": "1.61.1",
		"prettier": "3.8.4",
		"prettier-plugin-jsdoc": "1.8.1",
		"radashi": "12.9.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-intl": "10.1.13",
		"react-map-gl": "8.1.1",
		"semver": "7.8.5",
		"spin-delay": "2.0.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0",
		"utm": "1.1.1",
		"vite": "8.1.0",
		"vite-plugin-icons-spritesheet": "3.1.0",
		"vitest": "4.1.9"
	},
	"overrides": {
		"@comapeo/map-server": {
			"typebox": "1.1.27"
		},
		"@electron/packager": {
			"extract-zip": "npm:@electron-internal/extract-zip@1.0.3"
		},
		"@electron-forge/shared-types": {
			"tar": "7.5.16"
		},
		"better-sqlite3": "12.11.1",
		"tmp": "0.2.7"
	},
	"allowScripts": {
		"@sentry/cli@2.58.6": true,
		"better-sqlite3": false,
		"electron-winstaller@5.4.0": true,
		"fs-xattr": false,
		"fsevents": false,
		"macos-alias": false,
		"protobufjs": false
	}
}
