{
	"name": "comapeo-desktop",
	"productName": "CoMapeo Desktop",
	"private": true,
	"version": "0.3.0-pre",
	"description": "Desktop application for CoMapeo",
	"keywords": [],
	"author": {
		"name": "Awana Digital",
		"email": "info@awana.digital"
	},
	"contributors": [
		{
			"name": "Andrew Chou",
			"email": "andrewchou@fastmail.com"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/digidem/comapeo-desktop.git"
	},
	"license": "GPL-3.0",
	"type": "module",
	"main": "src/main/index.ts",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "~24.15.0",
			"onFail": "warn"
		},
		"packageManager": {
			"name": "npm",
			"version": "^11.13.0",
			"onFail": "warn"
		}
	},
	"scripts": {
		"postinstall": "patch-package",
		"prepare": "husky",
		"start": "node --run intl && node --run forge:start",
		"forge:start": "electron-forge start",
		"forge:package": "electron-forge package",
		"forge:make": "electron-forge make",
		"intl:extract": "node scripts/extract-messages.ts",
		"intl:compile": "node scripts/compile-messages.ts",
		"intl:generate-translated-languages-list": "node scripts/generate-translated-languages-list.ts",
		"intl": "node --run \"intl:extract\" && node --run \"intl:compile\"  && node --run \"intl:generate-translated-languages-list\"",
		"checks:eslint": "eslint --cache .",
		"checks:format": "prettier --cache --check .",
		"checks:knip": "knip --cache",
		"checks": "concurrently --prefix \"checks:{name}\" --pad-prefix --group \"node:checks:*\"",
		"types:root": "tsc -p tsconfig.json",
		"types:shared": "tsc -p src/shared/tsconfig.json",
		"types:main": "tsc -p src/main/tsconfig.json",
		"types:tests-e2e": "tsc -p tests-e2e/tsconfig.json",
		"types:services": "tsc -p src/services/tsconfig.json",
		"types:preload": "tsc -p src/preload/tsconfig.json",
		"types:renderer": "tsc -p src/renderer/tsconfig.json",
		"types": "concurrently --prefix \"types:{name}\" --pad-prefix --group \"node:types:*\"",
		"test:main": "vitest run --dir ./src/main/",
		"test:renderer": "vitest run --config ./src/renderer/vite.config.js",
		"test:shared": "vitest run --dir ./src/shared/",
		"test": "concurrently --prefix \"test:{name}\" --pad-prefix --group \"node:test:*\"",
		"test-e2e": "playwright test",
		"vite:dev": "vite dev src/renderer",
		"vite:build": "vite build src/renderer"
	},
	"dependencies": {
		"@comapeo/core": "7.1.0",
		"@comapeo/default-categories": "1.0.1",
		"@comapeo/fallback-smp": "1.0.0",
		"@comapeo/ipc": "8.0.0",
		"@comapeo/map-server": "1.1.3",
		"@formatjs/intl": "4.1.8",
		"@homebridge/ciao": "1.3.7",
		"@mapeo/crypto": "1.1.0",
		"@sentry/electron": "7.12.0",
		"atomically": "2.1.1",
		"debug": "4.4.3",
		"electron-context-menu": "4.1.2",
		"electron-dl": "4.0.0",
		"electron-squirrel-startup": "1.0.1",
		"fastify": "4.29.1",
		"sodium-native": "4.3.3",
		"systeminformation": "5.31.5",
		"tiny-typed-emitter": "2.1.0",
		"valibot": "1.3.1",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@comapeo/core-react": "11.0.4",
		"@electron-forge/cli": "7.11.1",
